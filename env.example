# ── JARVIS Bot - Variables de Entorno ──────────────────────────
# Renombra este archivo a .env y completa los valores

# 1. Token de tu bot de Telegram (obtenlo de @BotFather en Telegram)
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# 2. API Key de Anthropic (obtienla en https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# 3. (Opcional) IDs de Telegram autorizados, separados por coma
#    Deja vacío para permitir que cualquiera use el bot
#    Para obtener tu ID, escríbele a @userinfobot en Telegram
ALLOWED_USERS=123456789
